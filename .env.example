# Lấy từ @BotFather trên Telegram
BOT_TOKEN=your_bot_token_here

# Chat ID của người bán. Lấy bằng cách nhắn tin cho @userinfobot
SELLER_CHAT_ID=your_seller_chat_id_here

# Username của bot (không có @). Lấy từ @BotFather khi tạo bot
BOT_USERNAME=your_bot_username_here

# Tên hiển thị của quán (tuỳ chỉnh)
SHOP_NAME=Trà Sữa Nhà Mình

# ── Deploy settings ───────────────────────────────────────────────
# Để TRỐNG khi chạy local (sẽ dùng polling mode tự động)
# Điền URL server khi deploy lên Render / Railway
# VD Render:  https://trasua-bot.onrender.com
# VD Railway: https://trasua-bot.up.railway.app
WEBHOOK_URL=

# Port lắng nghe webhook — Railway tự gán, không cần điền
# Để mặc định 8443 khi chạy local
PORT=8443

# ── Lưu trữ dữ liệu ───────────────────────────────────────────────
# Để trống khi chạy local (dùng thư mục hiện tại)
# Railway: đặt DATA_DIR=/data và gắn Volume tại /data
DATA_DIR=
